# =============================================
# DARBA — Environment Variables Template
# Copy to .env.local / .env.dev / .env.test / .env.prod
# NEVER commit files with real values!
# =============================================

# === APP ===
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
APP_DOMAIN=localhost
CORS_ORIGINS=http://localhost:3000

# === DATABASE ===
POSTGRES_USER=darba
POSTGRES_PASSWORD=darba
POSTGRES_DB=darba
DATABASE_URL=postgresql://darba:darba@postgres:5432/darba

# Keycloak DB (separate DB in same PG instance)
KC_DB_NAME=keycloak

# === REDIS ===
REDIS_URL=redis://redis:6379

# === KEYCLOAK ===
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=darba
KEYCLOAK_CLIENT_ID=darba-api
KEYCLOAK_CLIENT_SECRET=

# === JWT ===
JWT_SECRET=changeme-use-random-256bit-string

# === ENCRYPTION (Fernet key for user API keys) ===
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === PAYMENTS ===
# ЮКасса (Russia)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Stripe (Europe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# === AI PROVIDERS (System keys) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STABILITY_API_KEY=
ELEVENLABS_API_KEY=
RUNWAYML_API_KEY=
DID_API_KEY=

# === EMAIL ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@darba.pro

# === STORAGE (S3-compatible) ===
S3_ENDPOINT=
S3_BUCKET=darba-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# === TELEGRAM (System bot) ===
TELEGRAM_BOT_TOKEN=

# === ADMIN ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
