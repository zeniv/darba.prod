generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// USERS
// =============================================

model User {
  id          String   @id @default(uuid())
  keycloakId  String   @unique @map("keycloak_id")
  username    String?  @unique
  email       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?

  // Тариф
  planId      String?  @map("plan_id")
  plan        Plan?    @relation(fields: [planId], references: [id])
  planExpiry  DateTime? @map("plan_expires_at")

  // Токены
  tokenBalance Int     @default(0) @map("token_balance")

  // Флаги
  isActive    Boolean  @default(true) @map("is_active")
  isAdmin     Boolean  @default(false) @map("is_admin")
  isVerified  Boolean  @default(false) @map("is_verified")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  posts          Post[]
  likes          Like[]
  comments       Comment[]
  donations      Donation[] @relation("donor")
  receivedDonations Donation[] @relation("recipient")
  followers      Follow[] @relation("following")
  following      Follow[] @relation("follower")
  payments       Payment[]
  aiTasks        AiTask[]
  integrations   UserIntegration[]
  tickets        SupportTicket[]
  notifications  Notification[]

  @@map("users")
}

// =============================================
// PLANS (тарифы)
// =============================================

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique  // "Free", "Max", "Pro" (кастомизируется)
  displayName String   @map("display_name")
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("RUB")
  period      String   @default("month")  // "month" | "year"
  tokens      Int      @default(0)
  features    Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  payments    Payment[]

  @@map("plans")
}

// =============================================
// PAYMENTS
// =============================================

model Payment {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id])
  planId         String   @map("plan_id")
  plan           Plan     @relation(fields: [planId], references: [id])

  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("RUB")
  provider       String   // "yookassa" | "stripe"
  providerPaymentId String? @map("provider_payment_id")

  status         String   @default("pending") // "pending" | "paid" | "failed" | "refunded"
  receipt        Json?

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

// =============================================
// CONTENT
// =============================================

model Post {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  title       String?
  content     String?
  mediaUrls   String[] @map("media_urls")
  mediaType   String?  @map("media_type")  // "image" | "video" | "audio"

  isPublic    Boolean  @default(true) @map("is_public")
  aiTaskId    String?  @map("ai_task_id")

  tags        String[] @default([])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  likes       Like[]
  comments    Comment[]

  @@map("posts")
}

// =============================================
// SOCIAL
// =============================================

model Like {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id])
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("comments")
}

model Donation {
  id          String   @id @default(uuid())
  donorId     String   @map("donor_id")
  donor       User     @relation("donor", fields: [donorId], references: [id])
  recipientId String   @map("recipient_id")
  recipient   User     @relation("recipient", fields: [recipientId], references: [id])
  amount      Int      // в токенах
  message     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("donations")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  follower    User     @relation("follower", fields: [followerId], references: [id])
  followingId String   @map("following_id")
  following   User     @relation("following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@map("follows")
}

// =============================================
// AI TASKS
// =============================================

model AiTask {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  agentType   String   @map("agent_type")  // "chat" | "txt2img" | "txt2video" | ...
  provider    String   // "anthropic" | "openai" | "stability" | ...
  params      Json     @default("{}")

  celeryTaskId String? @map("celery_task_id")
  status      String   @default("pending")  // "pending" | "running" | "done" | "error"
  result      String?
  mediaUrl    String?  @map("media_url")
  error       String?

  tokensUsed  Int      @default(0) @map("tokens_used")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ai_tasks")
}

// =============================================
// USER INTEGRATIONS
// =============================================

model UserIntegration {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id])

  type         String   // "ai_key" | "telegram" | "vk" | "instagram" | ...
  provider     String   // "openai" | "anthropic" | "telegram" | ...
  encryptedKey String?  @map("encrypted_key")
  metadata     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, type, provider])
  @@map("user_integrations")
}

// =============================================
// NOTIFICATIONS
// =============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  type      String   // "ai_done" | "like" | "comment" | "follow" | "payment"
  title     String
  body      String?
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// =============================================
// SUPPORT
// =============================================

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  subject   String
  status    String   @default("open")  // "open" | "in_progress" | "closed"
  priority  String   @default("normal")  // "low" | "normal" | "high"

  messages  SupportMessage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("support_tickets")
}

model SupportMessage {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])

  authorId  String?  @map("author_id")  // null = system
  isAdmin   Boolean  @default(false) @map("is_admin")
  content   String

  createdAt DateTime @default(now()) @map("created_at")

  @@map("support_messages")
}

// =============================================
// CMS PAGES (управляются из /admin/menu)
// =============================================

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique  // "offer", "disclaimer", etc.
  title     Json     @default("{}")  // {ru: "...", en: "..."}
  content   Json     @default("{}")  // {ru: "...", en: "..."}
  isPublic  Boolean  @default(true) @map("is_public")
  sortOrder Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model MenuItem {
  id        String   @id @default(uuid())
  parentId  String?  @map("parent_id")
  parent    MenuItem? @relation("children", fields: [parentId], references: [id])
  children  MenuItem[] @relation("children")

  label     Json     @default("{}")  // {ru: "...", en: "..."}
  url       String?
  icon      String?
  planIds   String[] @map("plan_ids")  // Доступно для этих тарифов (пусто = всем)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("menu_items")
}
