{
  "realm": "darba",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "ru"],
  "defaultLocale": "ru",
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "user", "description": "Regular user" },
      { "name": "admin", "description": "Admin user" },
      { "name": "manager", "description": "Manager user" }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "darba-frontend",
      "name": "Darba Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost/*",
        "https://darba.pro/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost",
        "https://darba.pro"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "darba-api",
      "name": "Darba API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "CHANGE_ME",
        "clientSecret": "CHANGE_ME",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "facebook",
      "providerId": "facebook",
      "enabled": false,
      "trustEmail": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "CHANGE_ME",
        "clientSecret": "CHANGE_ME",
        "defaultScope": "email,public_profile",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "apple",
      "providerId": "apple",
      "enabled": false,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "CHANGE_ME",
        "clientSecret": "CHANGE_ME",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "vk",
      "providerId": "vk",
      "enabled": false,
      "trustEmail": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "CHANGE_ME",
        "clientSecret": "CHANGE_ME",
        "fetchedFields": "photo_200,screen_name",
        "syncMode": "IMPORT"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "vk-username",
      "identityProviderAlias": "vk",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": {
        "attribute": "idp",
        "attribute.value": "vk",
        "syncMode": "INHERIT"
      }
    },
    {
      "name": "google-username",
      "identityProviderAlias": "google",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": {
        "attribute": "idp",
        "attribute.value": "google",
        "syncMode": "INHERIT"
      }
    }
  ],
  "smtpServer": {}
}
